NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
GROQ_API_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
ADMIN_EMAIL=
# Live interviewer voice-out (Google Cloud Text-to-Speech, Neural2 voices).
# Requires a GCP project with billing enabled (a card on file) — usage inside
# the free tier (1M chars/mo for Neural2) is $0, but the API key won't work
# without billing turned on. Optional: if unset, /api/voice/speak degrades
# cleanly to text-only, same as if the call ever failed.
GOOGLE_TTS_API_KEY=
GOOGLE_TTS_VOICE=en-US-Neural2-C

# Bearer token for GET /api/admin/smoke-check — a server-side twin of
# scripts/smoke/production-check.ts that a scheduled cloud agent can call
# without ever holding SUPABASE_SERVICE_ROLE_KEY. Generate with:
#   node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
SMOKE_CHECK_TOKEN=
