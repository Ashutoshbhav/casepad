{
  "name": "casepad",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "ingest:discover": "tsx scripts/ingest/discover.ts",
    "ingest:download": "tsx --env-file=.env.local scripts/ingest/download.ts",
    "ingest:run": "tsx --env-file=.env.local scripts/ingest/index.ts",
    "ingest:run:dry": "tsx --env-file=.env.local scripts/ingest/index.ts --dry-run",
    "ingest:run:disk": "tsx --env-file=.env.local scripts/ingest/index.ts --from-disk",
    "ingest:run:disk:dry": "tsx --env-file=.env.local scripts/ingest/index.ts --from-disk --dry-run",
    "ingest:second-pass": "tsx --env-file=.env.local scripts/ingest/run-second-pass.ts",
    "ingest:ocr": "python scripts/ingest/ocr-scanned.py",
    "pm-gate": "node scripts/pm-gate.mjs",
    "verify:urls": "tsx scripts/ingest/verify-urls.ts",
    "audit:pdfs": "tsx scripts/ingest/audit-pdfs.ts"
  },
  "dependencies": {
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.1",
    "cheerio": "^1.2.0",
    "groq-sdk": "^1.1.2",
    "motion": "^12.38.0",
    "next": "16.2.4",
    "pdf-parse": "^2.4.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "tesseract.js": "^7.0.0",
    "three": "^0.184.0",
    "zod": "^4.4.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "playwright": "^1.59.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
